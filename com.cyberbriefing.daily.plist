<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cyberbriefing.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/duncan/Documents/Program/scripts/cyberbriefing/.venv/bin/python</string>
        <string>/Users/duncan/Documents/Program/scripts/cyberbriefing/briefing.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/duncan/Documents/Program/scripts/cyberbriefing</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/cyberbriefing.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/cyberbriefing.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
